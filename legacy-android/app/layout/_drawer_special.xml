<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<ScrollView
		android:id="@+id/vscroll3"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:padding="8dp"
		android:background="#282828">
		<LinearLayout
			android:id="@+id/droplist"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:padding="4dp"
			android:background="#EFB775"
			android:gravity="top"
			android:orientation="horizontal">
			<LinearLayout
				android:id="@+id/menulist"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="#A56243"
				android:orientation="vertical">
				<TextView
					android:id="@+id/textview172"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_margin="2dp"
					android:padding="2dp"
					android:background="#EFB775"
					android:text="  Categories:"
					android:textSize="18sp"
					android:textStyle="bold|italic"
					android:textColor="#773421" />
				<ScrollView
					android:id="@+id/vscroll2"
					android:layout_width="match_parent"
					android:layout_height="wrap_content">
					<LinearLayout
						android:id="@+id/linear460"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="vertical">
						<LinearLayout
							android:id="@+id/so1"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:paddingLeft="8dp"
							android:paddingTop="5dp"
							android:paddingRight="8dp"
							android:paddingBottom="5dp"
							android:orientation="horizontal">
							<ImageView
								android:id="@+id/imageview1"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:src="@drawable/default_image"
								android:scaleType="center" />
							<LinearLayout
								android:id="@+id/linear456"
								android:layout_width="match_parent"
								android:layout_height="match_parent"
								android:paddingLeft="8dp"
								android:paddingRight="8dp"
								android:gravity="left|center_vertical"
								android:orientation="vertical">
								<TextView
									android:id="@+id/textview173"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:paddingLeft="8dp"
									android:paddingRight="8dp"
									android:gravity="left|center_vertical"
									android:text="PROTOTYPE"
									android:textSize="16sp"
									android:textStyle="bold"
									android:textColor="#FFE2C1" />
								<TextView
									android:id="@+id/textview429"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:paddingLeft="8dp"
									android:paddingRight="8dp"
									android:paddingBottom="8dp"
									android:gravity="left|center_vertical"
									android:text="#S01 - #S06"
									android:textSize="12sp"
									android:textStyle="bold"
									android:textColor="#FFE2C1" />
							</LinearLayout>
						</LinearLayout>
						<LinearLayout
							android:id="@+id/so2"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:paddingLeft="8dp"
							android:paddingTop="5dp"
							android:paddingRight="8dp"
							android:paddingBottom="5dp"
							android:orientation="horizontal">
							<ImageView
								android:id="@+id/imageview3"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:src="@drawable/default_image"
								android:scaleType="center" />
							<LinearLayout
								android:id="@+id/linear458"
								android:layout_width="match_parent"
								android:layout_height="match_parent"
								android:paddingLeft="8dp"
								android:paddingRight="8dp"
								android:gravity="left|center_vertical"
								android:orientation="vertical">
								<TextView
									android:id="@+id/textview433"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:paddingLeft="8dp"
									android:paddingRight="8dp"
									android:gravity="left|center_vertical"
									android:text="JUNIOR"
									android:textSize="16sp"
									android:textStyle="bold"
									android:textColor="#FFE2C1" />
								<TextView
									android:id="@+id/textview434"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:paddingLeft="8dp"
									android:paddingRight="8dp"
									android:paddingBottom="8dp"
									android:gravity="left|center_vertical"
									android:text="#S07 - #S12"
									android:textSize="12sp"
									android:textStyle="bold"
									android:textColor="#FFE2C1" />
							</LinearLayout>
						</LinearLayout>
						<LinearLayout
							android:id="@+id/so3"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:paddingLeft="8dp"
							android:paddingTop="5dp"
							android:paddingRight="8dp"
							android:paddingBottom="5dp"
							android:orientation="horizontal">
							<ImageView
								android:id="@+id/imageview4"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:src="@drawable/default_image"
								android:scaleType="center" />
							<LinearLayout
								android:id="@+id/linear1126"
								android:layout_width="match_parent"
								android:layout_height="match_parent"
								android:paddingLeft="8dp"
								android:paddingRight="8dp"
								android:gravity="left|center_vertical"
								android:orientation="vertical">
								<TextView
									android:id="@+id/textview435"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:paddingLeft="8dp"
									android:paddingRight="8dp"
									android:gravity="left|center_vertical"
									android:text="PERCORN"
									android:textSize="16sp"
									android:textStyle="bold"
									android:textColor="#FFE2C1" />
								<TextView
									android:id="@+id/textview436"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:paddingLeft="8dp"
									android:paddingRight="8dp"
									android:paddingBottom="8dp"
									android:gravity="left|center_vertical"
									android:text="#S13 - #S18"
									android:textSize="12sp"
									android:textStyle="bold"
									android:textColor="#FFE2C1" />
							</LinearLayout>
						</LinearLayout>
					</LinearLayout>
				</ScrollView>
			</LinearLayout>
		</LinearLayout>
	</ScrollView>
</LinearLayout>
