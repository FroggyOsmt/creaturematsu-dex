<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/dialogdesc"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="8dp"
		android:background="#282828"
		android:orientation="vertical">
		<LinearLayout
			android:id="@+id/linear46"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:background="#A36042"
			android:orientation="horizontal">
			<LinearLayout
				android:id="@+id/titleround"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:padding="5dp"
				android:background="#EFB775"
				android:gravity="center_vertical"
				android:orientation="horizontal">
				<ImageView
					android:id="@+id/icon"
					android:focusable="false"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:src="@drawable/unknown_000"
					android:scaleType="center" />
				<TextView
					android:id="@+id/name"
					android:focusable="false"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="#000 - NAME"
					android:textSize="20sp"
					android:textStyle="bold"
					android:textColor="#763420" />
			</LinearLayout>
		</LinearLayout>
		<LinearLayout
			android:id="@+id/linear4"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:background="#FFECB3"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="horizontal">
			<LinearLayout
				android:id="@+id/linear48"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="5dp"
				android:background="#FFECB3"
				android:gravity="bottom"
				android:orientation="horizontal"
				android:layout_gravity="bottom">
				<ImageView
					android:id="@+id/imageview2"
					android:focusable="false"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:src="@drawable/inv_group"
					android:scaleType="center" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/linear51"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:orientation="horizontal">
				<com.github.chrisbanes.photoview.PhotoView
					android:id="@+id/image"
					android:focusable="false"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:src="@drawable/unknown_000"
					android:layout_gravity="center_horizontal|center_vertical" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/linear47"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="5dp"
				android:gravity="bottom"
				android:orientation="horizontal"
				android:layout_gravity="bottom">
				<ImageView
					android:id="@+id/imageview1"
					android:focusable="false"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:src="@drawable/groupimage"
					android:scaleType="center" />
			</LinearLayout>
		</LinearLayout>
		<LinearLayout
			android:id="@+id/desc_navi"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:background="#A56243"
			android:orientation="horizontal">
			<LinearLayout
				android:id="@+id/linear50"
				android:layout_width="320dp"
				android:layout_height="wrap_content"
				android:orientation="vertical">
				<TextView
					android:id="@+id/desc"
					android:focusable="false"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:paddingLeft="8dp"
					android:paddingTop="2dp"
					android:paddingRight="8dp"
					android:paddingBottom="2dp"
					android:background="#EFB775"
					android:text="DESCRIPTION:"
					android:textSize="12sp"
					android:textStyle="bold|italic"
					android:textColor="#773421" />
				<LinearLayout
					android:id="@+id/linear3"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:background="#FFE2C1"
					android:orientation="vertical">
					<TextView
						android:id="@+id/text"
						android:focusable="false"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginLeft="6dp"
						android:layout_marginTop="1dp"
						android:layout_marginRight="6dp"
						android:layout_marginBottom="3dp"
						android:text="TBA"
						android:textSize="14sp"
						android:textStyle="italic"
						android:textColor="#773421" />
				</LinearLayout>
			</LinearLayout>
			<LinearLayout
				android:id="@+id/navi_1"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="#763420"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical">
				<ImageView
					android:id="@+id/imageview3"
					android:focusable="false"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:src="@drawable/ic_navigate_next_white"
					android:scaleType="centerCrop"
					android:scaleX="1.5"
					android:scaleY="1.5" />
			</LinearLayout>
		</LinearLayout>
		<LinearLayout
			android:id="@+id/origin_navi"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:background="#A56243"
			android:orientation="horizontal">
			<LinearLayout
				android:id="@+id/linear54"
				android:layout_width="320dp"
				android:layout_height="wrap_content"
				android:orientation="vertical">
				<TextView
					android:id="@+id/origin"
					android:focusable="false"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:paddingLeft="8dp"
					android:paddingTop="2dp"
					android:paddingRight="8dp"
					android:paddingBottom="2dp"
					android:background="#EFB775"
					android:text="ORIGIN:"
					android:textSize="12sp"
					android:textStyle="bold|italic"
					android:textColor="#773421" />
				<LinearLayout
					android:id="@+id/linear56"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:background="#FFE2C1"
					android:orientation="vertical">
					<TextView
						android:id="@+id/text_o"
						android:focusable="false"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginLeft="6dp"
						android:layout_marginTop="1dp"
						android:layout_marginRight="6dp"
						android:layout_marginBottom="3dp"
						android:text="TBA"
						android:textSize="14sp"
						android:textStyle="italic"
						android:textColor="#773421" />
				</LinearLayout>
			</LinearLayout>
			<LinearLayout
				android:id="@+id/navi_2"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="#763420"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical">
				<ImageView
					android:id="@+id/imageview4"
					android:focusable="false"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:src="@drawable/ic_navigate_next_white"
					android:scaleType="centerCrop"
					android:scaleX="1.5"
					android:scaleY="1.5" />
			</LinearLayout>
		</LinearLayout>
		<LinearLayout
			android:id="@+id/ref_navi"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:background="#A56243"
			android:orientation="horizontal">
			<LinearLayout
				android:id="@+id/linear58"
				android:layout_width="320dp"
				android:layout_height="wrap_content"
				android:orientation="vertical">
				<TextView
					android:id="@+id/ref"
					android:focusable="false"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:paddingLeft="8dp"
					android:paddingTop="2dp"
					android:paddingRight="8dp"
					android:paddingBottom="2dp"
					android:background="#EFB775"
					android:text="REFERENCE FROM OSOMATSU-SAN OR OUR PAST:"
					android:textSize="12sp"
					android:textStyle="bold|italic"
					android:textColor="#773421" />
				<LinearLayout
					android:id="@+id/linear59"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:background="#FFE2C1"
					android:orientation="vertical">
					<TextView
						android:id="@+id/text_r"
						android:focusable="false"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginLeft="6dp"
						android:layout_marginTop="1dp"
						android:layout_marginRight="6dp"
						android:layout_marginBottom="3dp"
						android:text="TBA"
						android:textSize="14sp"
						android:textStyle="italic"
						android:textColor="#773421" />
				</LinearLayout>
			</LinearLayout>
			<LinearLayout
				android:id="@+id/navi_3"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="#763420"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical">
				<ImageView
					android:id="@+id/imageview5"
					android:focusable="false"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:src="@drawable/ic_navigate_next_white"
					android:scaleType="centerCrop"
					android:scaleX="1.5"
					android:scaleY="1.5" />
			</LinearLayout>
		</LinearLayout>
		<LinearLayout
			android:id="@+id/linear33"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:paddingLeft="8dp"
			android:paddingRight="8dp"
			android:paddingBottom="8dp"
			android:background="#A56243"
			android:orientation="horizontal">
			<LinearLayout
				android:id="@+id/linear34"
				android:layout_width="80dp"
				android:layout_height="wrap_content"
				android:background="#FFE2C1"
				android:orientation="vertical">
				<TextView
					android:id="@+id/textview9"
					android:focusable="false"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:paddingLeft="8dp"
					android:paddingTop="2dp"
					android:paddingRight="8dp"
					android:paddingBottom="2dp"
					android:background="#EFB775"
					android:text="SIZE:"
					android:textSize="12sp"
					android:textStyle="bold|italic"
					android:textColor="#773421" />
				<TextView
					android:id="@+id/size"
					android:focusable="false"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginLeft="6dp"
					android:layout_marginTop="1dp"
					android:layout_marginRight="6dp"
					android:layout_marginBottom="3dp"
					android:text="100 cm"
					android:textSize="14sp"
					android:textStyle="italic"
					android:textColor="#773421" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/linear40"
				android:layout_width="9dp"
				android:layout_height="match_parent"
				android:padding="8dp"
				android:orientation="horizontal" />
			<LinearLayout
				android:id="@+id/linear41"
				android:layout_width="80dp"
				android:layout_height="match_parent"
				android:background="#FFE2C1"
				android:orientation="vertical">
				<TextView
					android:id="@+id/textview15"
					android:focusable="false"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:paddingLeft="8dp"
					android:paddingTop="2dp"
					android:paddingRight="8dp"
					android:paddingBottom="2dp"
					android:background="#EFB775"
					android:text="MATSU:"
					android:textSize="12sp"
					android:textStyle="bold|italic"
					android:textColor="#773421" />
				<TextView
					android:id="@+id/matsutype"
					android:focusable="false"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginLeft="6dp"
					android:layout_marginTop="1dp"
					android:layout_marginRight="6dp"
					android:layout_marginBottom="3dp"
					android:text="OSO"
					android:textSize="14sp"
					android:textStyle="italic"
					android:textColor="#773421" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/linear36"
				android:layout_width="9dp"
				android:layout_height="match_parent"
				android:padding="8dp"
				android:orientation="vertical" />
			<LinearLayout
				android:id="@+id/linear43"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="#FFE2C1"
				android:orientation="vertical">
				<TextView
					android:id="@+id/textview14"
					android:focusable="false"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:paddingLeft="8dp"
					android:paddingTop="2dp"
					android:paddingRight="8dp"
					android:paddingBottom="2dp"
					android:background="#EFB775"
					android:text="CATEGORY:"
					android:textSize="12sp"
					android:textStyle="bold|italic"
					android:textColor="#773421" />
				<TextView
					android:id="@+id/category"
					android:focusable="false"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginLeft="6dp"
					android:layout_marginTop="1dp"
					android:layout_marginRight="6dp"
					android:layout_marginBottom="3dp"
					android:text="TextView"
					android:textSize="14sp"
					android:textStyle="italic"
					android:textColor="#773421" />
			</LinearLayout>
		</LinearLayout>
	</LinearLayout>
</LinearLayout>
